        "string"
      ]
    }
  ],
  "return": {
    "types": [
      "string"
    ]
  },
  "examples": [
    {
      "title": "Strip ANSI escape codes",
      "source": "strip_ansi_escape_codes(\"\\e[46mfoo\\e[0m bar\")",
